# Credentials template for PlanTrail — copy to ".env" and fill in real values.
# ".env" is gitignored (never committed). This ".env.example" has NO real secrets.
#
# Local runs: trail_analyzer.py reads these from the environment if set; otherwise
# it falls back to the gitignored strava_token.json (which already holds the secret
# and refresh token). Export them in your shell, or use a tool that loads .env.
#
# Part B (GitHub Actions daily job): add these as encrypted repo Secrets
# (Settings -> Secrets and variables -> Actions), NOT in any committed file.

# --- Strava (https://www.strava.com/settings/api) ---
STRAVA_CLIENT_ID=114720
STRAVA_CLIENT_SECRET=your_rotated_client_secret_here
STRAVA_REFRESH_TOKEN=your_strava_refresh_token_here

# --- Anthropic (only needed for Part B per-training LLM coaching) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
